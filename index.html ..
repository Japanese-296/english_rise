  Router.register('conversation', ()    => Pages.conversation());
  Router.register('quiz',         ()    => Pages.quiz());
  Router.register('progress',     ()    => Pages.progress());
  Router.register('profile',      ()    => Pages.profile());
  Router.register('level',        (pg)  => Pages.level(pg));

  const startPage = window.location.hash.replace('#','') || 'dashboard';
  Router.go(startPage);

  window.addEventListener('popstate', () => {
    const hash = window.location.hash.replace('#','') || 'dashboard';
    Router.go(hash);
  });
};
</script>

<script src="languages.js"></script>
<script>
// Redirect to language selector if not chosen
if (!localStorage.getItem("speakrise_lang")) {
  window.location.replace("select-language.html");
}
// Apply translations to sidebar
document.addEventListener("ez:userReady", function() {
  const lang = localStorage.getItem("speakrise_lang") || "en";
  const t = (typeof UI_TEXT !== "undefined") ? (UI_TEXT[lang] || UI_TEXT.en) : null;
  const L = (typeof LANGUAGES !== "undefined") ? LANGUAGES[lang] : null;
  if (t && L) {
    window._srLang = lang; window._srT = t; window._srL = L;
    // Update sidebar nav labels
    const navMap = {
      "nav-dashboard": t.dashboard,
      "nav-vocab": t.vocabulary,
      "nav-grammar": t.grammar,
      "nav-reading": t.reading,
      "nav-conversation": t.conversation,
      "nav-quiz": t.quiz,
      "nav-progress": t.progress,
      "nav-profile": t.profile
    };
    Object.entries(navMap).forEach(([id, label]) => {
      const el = document.getElementById(id);
      if (el) {
        const icon = el.querySelector(".nav-icon");
        const badge = el.querySelector(".nav-badge");
        el.textContent = label;
        if (icon) el.prepend(icon);
        if (badge) el.append(badge);
      }
    });
    // Auth loading text
    const alt = document.querySelector(".auth-loading-text");
    if (alt) alt.innerHTML = (t.loading || "Loading SpeakRise") + "<span class='auth-loading-dots'></span>";
    // Change lang button in sidebar footer
    const signout = document.querySelector(".btn-signout");
    if (signout) {
      const langBtn = document.createElement("button");
      langBtn.className = "btn-signout";
      langBtn.style.color = "var(--primary)";
      langBtn.textContent = "🌐 " + L.flag + " " + L.native;
      langBtn.onclick = () => window.location.href = "select-language.html";
      signout.parentNode.insertBefore(langBtn, signout);
    }
  }
});
</script></body>
</html>
