/* ─────────── QUIZ ─────────── */
quiz() {
  setHeader('Quiz', 'प्रश्नोत्तरी — Test Your English');
  const el = document.getElementById('page-content');
  const questions = QUIZ_DATA.A1;
  let current = 0, score = 0, answered = false;

  function renderQuiz() {
    if (current >= questions.length) {
      const pct = Math.round((score / questions.length) * 100);
      el.innerHTML = `
      <div class="card" style="max-width:480px;margin:0 auto;text-align:center;padding:36px 28px" class="anim-fade-up">
        <div style="font-size:56px;margin-bottom:16px">${pct>=80?'🏆':pct>=60?'👍':'💪'}</div>
        <div style="font-size:24px;font-weight:800;color:var(--fg);margin-bottom:8px">Quiz Complete!</div>
        <div style="font-family:var(--font-hindi);font-size:14px;color:var(--fg-muted);margin-bottom:20px">Quiz पूरा हुआ!</div>
        <div style="font-size:40px;font-weight:900;color:${pct>=80?'var(--success)':pct>=60?'var(--warning)':'var(--danger)'};margin-bottom:6px">${score}/${questions.length}</div>
        <div style="font-size:14px;color:var(--fg-muted);margin-bottom:24px">${pct}% Accuracy</div>
        <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
          <button class="btn btn-primary btn-lg" onclick="Pages.quiz()">Try Again 🔄</button>
          <button class="btn btn-secondary btn-lg" onclick="Router.go('dashboard')">Dashboard</button>
        </div>
      </div>
      `;
      if (pct >= 60) { window._ezAddXP && window._ezAddXP(50); showToast(`Quiz done! ${score}/${questions.length} correct · +50 XP 🎉`, 'success'); }
      return;
    }

    const q = questions[current];
    el.innerHTML = `
    <!-- Progress -->
    <div class="card anim-fade-up d1" style="margin-bottom:16px;max-width:600px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
        <div style="font-size:12px;font-weight:700;color:var(--fg-muted)">Question ${current+1} of ${questions.length}</div>
        <div style="font-size:12px;font-weight:700;color:var(--success)">Score: ${score}</div>
      </div>
      <div class="progress-bar">
        <div class="progress-bar-fill" style="width:${(current/questions.length)*100}%;background:var(--primary)"></div>
      </div>
    </div>

    <!-- Question -->
    <div class="card anim-fade-up d2" style="max-width:600px">
      <div style="padding:6px 12px;border-radius:99px;background:var(--primary-dim);color:var(--primary);font-size:11px;font-weight:700;display:inline-block;margin-bottom:14px">A1 · Vocabulary</div>
      <div class="quiz-question">${q.q}</div>
      <div class="quiz-hindi">${q.qHindi}</div>
      <div class="quiz-options" id="quiz-opts">
        ${q.options.map((opt, i) => `
          <button class="quiz-option" id="opt-${i}" onclick="selectAnswer(${i})">
            <span style="font-size:12px;font-weight:700;color:var(--fg-subtle);margin-right:8px">${String.fromCharCode(65+i)}.</span>
            ${opt}
          </button>
        `).join('')}
      </div>
      <div id="quiz-feedback" style="display:none;margin-top:14px"></div>
      <div id="next-btn" style="display:none;margin-top:14px">
        <button class="btn btn-primary btn-lg" onclick="nextQuestion()">
          ${current+1 === questions.length ? 'See Results 🏆' : 'Next Question →'}
        </button>
      </div>
    </div>
    `;

    window.selectAnswer = (idx) => {
      if (answered) return;
      answered = true;
      const correct = q.correct;
      const isCorrect = idx === correct;
      if (isCorrect) score++;

      document.querySelectorAll('.quiz-option').forEach((btn, i) => {
        btn.style.pointerEvents = 'none';
        if (i === correct) btn.classList.add('correct');
        else if (i === idx && !isCorrect) btn.classList.add('wrong');
      });

      const fb = document.getElementById('quiz-feedback');
      fb.style.display = 'block';
      fb.innerHTML = `
        <div style="padding:12px 16px;border-radius:var(--radius);background:${isCorrect?'var(--success-dim)':'rgba(239,68,68,0.08)'};border:1px solid ${isCorrect?'var(--success)':'var(--danger)'}">
          <div style="font-size:14px;font-weight:700;color:${isCorrect?'var(--success)':'var(--danger)'}">
            ${isCorrect?'✅ Correct! Shabash! / शाबाश!':'❌ Wrong. Sahi jawab / सही जवाब:'}
          </div>
          ${!isCorrect?`<div style="font-size:13px;margin-top:4px;color:var(--fg);font-weight:600">${q.options[correct]}</div>`:''}
        </div>
      `;
      document.getElementById('next-btn').style.display = 'block';
      if (isCorrect) showToast('Correct! +10 XP ⚡', 'success');
    };

    window.nextQuestion = () => { current++; answered = false; renderQuiz(); };
  }

  renderQuiz();
},

