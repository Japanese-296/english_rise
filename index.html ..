<script>
'use strict';

const State = {
  state: {
    user: null, userData: null,
    xp: 0, xpGoal: 500, levelXP: 0, levelXPRequired: 200,
    streak: 1, level: 1, coins: 0,
    currentCEFR: 'A1',
    lessonsCompleted: 0, vocabMastered: 0, quizAccuracy: 0,
    currentPage: 'dashboard'
  },
  syncFromFirestore(d) {
    if (!d) return;
    this.state.xp = d.xp || 0;
    this.state.xpGoal = d.xpGoal || 500;
    this.state.levelXP = d.levelXP || 0;
    this.state.levelXPRequired = d.levelXPRequired || 200;
    this.state.streak = d.streak || 1;
    this.state.level = d.level || 1;
    this.state.coins = d.coinsEarned || 0;
    this.state.currentCEFR = d.currentCEFR || 'A1';
    this.state.lessonsCompleted = d.lessonsCompleted || 0;
    this.state.vocabMastered = d.vocabMastered || 0;
    this.state.quizAccuracy = d.quizAccuracy || 0;
  }
};

const Router = {
  _routes: {},
  register(name, fn) { this._routes[name] = fn; },
  go(page) {
    State.state.currentPage = page;
    window.location.hash = page;
    // Update active nav
    document.querySelectorAll('.nav-item, .cefr-nav-item').forEach(el => el.classList.remove('active'));
    const navEl = document.getElementById('nav-' + page.split('-')[0]);
    if (navEl) navEl.classList.add('active');
    // Scroll top
    document.getElementById('page-content')?.scrollTo(0, 0);
    window.scrollTo(0, 0);
    // Close mobile sidebar
    closeSidebar();
    // Run page
    const fn = this._routes[page] || this._routes[page.split('-')[0]];
    if (fn) {
      const content = document.getElementById('page-content');
      content.innerHTML = '';
      fn(page);
    }
  }
};

function updateSidebarUI() {
  const s = State.state;
  const u = window._ezUser;
  const d = window._ezUserData;

  // Avatar
  const avatarEl = document.getElementById('user-avatar');
  if (u?.photoURL) {
    avatarEl.innerHTML = `<img src="${u.photoURL}" alt="avatar"/>`;
  } else {
    const name = (u?.displayName || d?.displayName || 'L');
    avatarEl.textContent = name.charAt(0).toUpperCase();
  }

  document.getElementById('user-name').textContent = u?.displayName || d?.displayName || 'Learner';
  document.getElementById('user-level-label').textContent = `Level ${s.level} · ${s.currentCEFR} ${cefrLabel(s.currentCEFR)}`;

  const pct = Math.min((s.levelXP / s.levelXPRequired) * 100, 100);
  document.getElementById('sidebar-xp-fill').style.width = pct + '%';
  document.getElementById('sidebar-xp-text').textContent = `${s.levelXP} / ${s.levelXPRequired}`;
  document.getElementById('sidebar-streak').textContent = `${s.streak} Day${s.streak !== 1 ? 's' : ''} Streak`;
  document.getElementById('sidebar-coins').textContent = `${s.coins} Coins`;

  // Header
  document.getElementById('header-xp').textContent = s.xp;
  document.getElementById('header-streak').textContent = s.streak;
}

function cefrLabel(code) {
  const map = { A1:'Beginner', A2:'Elementary', B1:'Intermediate', B2:'Upper-Int', C1:'Advanced', C2:'Proficiency' };
  return map[code] || '';
}

function openSidebar() {
  document.getElementById('sidebar').classList.add('open');
  document.getElementById('sidebar-overlay').classList.add('visible');
}
function closeSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebar-overlay').classList.remove('visible');
}

function showToast(msg, type = 'info') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = msg;
  container.appendChild(toast);
  setTimeout(() => { toast.classList.add('out'); setTimeout(() => toast.remove(), 300); }, 3000);
}
window.showToast = showToast;
</script>

