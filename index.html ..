/* ─────────── VOCABULARY ─────────── */
vocab(page) {
  setHeader('Vocabulary', 'शब्द-भंडार — English Words with Hindi Meanings');
  const el = document.getElementById('page-content');
  const levels = Object.keys(VOCAB_DATA);
  let currentLevel = 'A1';
  let searchQuery = '';

  function render() {
    const words = (VOCAB_DATA[currentLevel] || []).filter(w =>
      !searchQuery || w.word.toLowerCase().includes(searchQuery.toLowerCase()) || w.hindi.includes(searchQuery)
    );
    el.innerHTML = `
    <!-- Level Tabs -->
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px" class="anim-fade-in">
      ${levels.map(lv => `
        <button onclick="setLevel('${lv}')" style="padding:7px 16px;border-radius:99px;border:1.5px solid ${lv===currentLevel?cefrColor(lv):'var(--border)'};background:${lv===currentLevel?cefrDim(lv):'transparent'};color:${lv===currentLevel?cefrColor(lv):'var(--fg-muted)'};font-family:var(--font-sans);font-size:12px;font-weight:700;cursor:pointer">
          ${cefrEmoji(lv)} ${lv}
        </button>
      `).join('')}
    </div>

    <!-- Search -->
    <div style="position:relative;margin-bottom:20px" class="anim-fade-in">
      <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--fg-muted)" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input id="vocab-search" type="text" placeholder="Search words / हिंदी में खोजें..." value="${searchQuery}"
        style="width:100%;padding:11px 14px 11px 38px;border-radius:var(--radius);border:1.5px solid var(--border);background:var(--card);font-family:var(--font-sans);font-size:14px;color:var(--fg);outline:none"
        oninput="onSearch(this.value)" />
    </div>

    <!-- Word count info -->
    <div style="margin-bottom:16px;font-size:13px;color:var(--fg-muted)" class="anim-fade-in">
      <span style="font-weight:700;color:${cefrColor(currentLevel)}">${currentLevel}</span> level — 
      <span style="font-weight:600">${words.length} word${words.length!==1?'s':''}</span>
      <span style="font-family:var(--font-hindi)"> मिले</span>
    </div>

    <!-- Words Grid -->
    <div class="grid-3 anim-fade-in" id="words-grid">
      ${words.length ? words.map((w,i) => `
        <div class="word-card" style="animation-delay:${i*0.04}s">
          <div class="word-en">${w.word}</div>
          <div class="word-hi">${w.hindi}</div>
          <div style="font-size:11px;color:var(--fg-subtle);margin-bottom:6px;font-family:var(--font-mono)">[${w.pronunciation}]</div>
          <div class="word-example">"${w.example}"</div>
          <div class="word-example-hindi">"${w.exHindi}"</div>
          <div class="word-level-badge" style="background:${cefrDim(currentLevel)};color:${cefrColor(currentLevel)}">${currentLevel}</div>
        </div>
      `).join('') : `
        <div class="empty-state" style="grid-column:1/-1">
          <div class="empty-icon">🔍</div>
          <div class="empty-title">No words found</div>
          <div class="empty-desc">Try a different search term</div>
        </div>
      `}
    </div>
    `;
  }

  window.setLevel = (lv) => { currentLevel = lv; render(); };
  window.onSearch = (q) => { searchQuery = q; render(); };
  render();
},

